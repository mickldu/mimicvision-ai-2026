.claude/
__pycache__/
*.pyc
.venv/
venv/
*.joblib
*.pkl
*.faiss
*.task
.ipynb_checkpoints/
# dentro de data/raw solo se versiona el registro de licencias; git no
# entra a directorios ignorados por completo, por eso el patron con *
data/raw/*
!data/raw/cc_registro.csv
data/images/
# caches de embeddings/descriptores de MATCH: se regeneran solos desde
# el notebook D2, no hace falta versionarlos (a diferencia de
# features_mimic.csv, que es mucho mas liviano)
data/match_*.npz
# los videos crudos/compuestos de ASK no se versionan, solo el script
# que los descarga+concatena y el registro de fuentes/licencias
data/videos/*
!data/videos/video_prueba_registro.csv
